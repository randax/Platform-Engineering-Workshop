# =============================================================================
# CloudBox — single source of truth for every version pin used by scripts/.
#
# Sourced by every script via scripts/lib.sh. Principle 14: pin everything.
# Tool versions (talosctl, kubectl, helm, kind, crane, node) are pinned in
# mise.toml — keep the two files in sync when bumping.
#
# Verified against upstream releases on 2026-07-13. Re-verify late August
# before the final `javazone-2026` tag.
# =============================================================================

# --- Tooling -------------------------------------------------------------------
# mise version installed by dev-setup.sh / CI / devcontainer (the mise.run
# installer honors MISE_VERSION). Keep the devcontainer copy in sync.
MISE_VERSION="v2026.7.3"

# --- Cluster -----------------------------------------------------------------
CLUSTER_NAME="cloudbox"
TALOS_VERSION="v1.13.6"                      # never 1.12.x — cni:none hangs (talos#12885)
TALOS_IMAGE="ghcr.io/siderolabs/talos:${TALOS_VERSION}"
KUBERNETES_VERSION="1.36.2"                  # what Talos v1.13.6 ships by default
TALOS_SUBNET="10.5.0.0/24"                   # talosctl default, pinned so the gateway
TALOS_SUBNET_GATEWAY="10.5.0.1"              # (= the host, on Linux) is predictable

# Memory limits per node container (MB). Defaults (2048) will NOT fit the stack.
TALOS_MEMORY_CONTROLPLANE="4096"
TALOS_MEMORY_WORKER="6144"

# --- kind fallback (loses the Talos content, strictly more robust) -----------
KIND_NODE_IMAGE="kindest/node:v1.36.1@sha256:3489c7674813ba5d8b1a9977baea8a6e553784dab7b84759d1014dbd78f7ebd5"

# --- CNI ----------------------------------------------------------------------
CILIUM_VERSION="1.19.5"
CILIUM_HELM_REPO="https://helm.cilium.io"

# --- GitOps -------------------------------------------------------------------
GITEA_CHART_VERSION="12.6.0"                 # ships Gitea 1.26.1
GITEA_HELM_REPO="https://dl.gitea.com/charts/"
GITEA_ADMIN_USER="gitea_admin"
GITEA_ADMIN_PASSWORD="cloudbox123"           # ephemeral lab cluster — not a secret
GITEA_HOST_URL="http://localhost:30300"
GITEA_CLUSTER_URL="http://gitea-http.gitea.svc.cluster.local:3000"
PLATFORM_REPO_PATH="cloudbox/platform"       # <org>/<repo>, created by push-to-create

ARGOCD_VERSION="v3.4.5"
ARGOCD_HOST_URL="http://localhost:30080"

# Installed imperatively by bootstrap-gitops.sh (Gitea's PVC needs a storage
# class before GitOps exists) directly from the gitops component, which the
# wave-0 ArgoCD app adopts afterwards — single copy, cannot drift.
LOCAL_PATH_PROVISIONER_VERSION="v0.0.36"

# Knative Eventing release vendored into gitops/components/knative-eventing/
# (module 09 capstone). Documented here so images.txt re-pins have one anchor.
KNATIVE_EVENTING_VERSION="v1.22.2"

# --- NodePorts exposed on the host --------------------------------------------
NODEPORT_GITEA="30300"
NODEPORT_ARGOCD="30080"
NODEPORT_ZOT="30500"
NODEPORT_PORTAL="30600"
NODEPORT_BACKSTAGE="30700"
NODEPORT_RUSTFS_S3="30900"
NODEPORT_KOURIER="31080"

# --- Image pre-pull mirror (created by cloudbox-init.sh) ----------------------
MIRROR_NAME="cloudbox-mirror"
MIRROR_PORT="5001"
MIRROR_VOLUME="cloudbox-mirror-data"
MIRROR_IMAGE="docker.io/library/registry:3.1.1"

# --- Published minimum spec (install.sh --check thresholds) -------------------
MIN_DOCKER_MEMORY_GB="10"                    # allocatable to Docker
MIN_CPUS="4"
MIN_DISK_FREE_GB="40"
